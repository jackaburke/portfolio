---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Pager from '../components/Pager.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site.config';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured);
const others = projects.filter((p) => !p.data.featured);

const PER_PAGE = 3;
const otherPages = Math.max(1, Math.ceil(others.length / PER_PAGE));
---

<Layout>
  <Navbar />

  <div class="lg:flex">
    <Sidebar />

    <div class="flex-1 min-w-0 lg:flex lg:flex-col">
      <main id="main" class="lg:flex-1 lg:px-12 lg:pt-12 scroll-mt-[56px] lg:scroll-mt-[var(--nav-h)]">
        <section class="p-6 border-b border-divider lg:p-0 lg:pb-11 lg:mb-12">
          <p
            class="max-w-[660px] text-[clamp(20px,6.2vw,26px)] leading-[1.4] lg:text-[26px] font-medium tracking-[-.01em] [text-wrap:pretty]"
          >
            {site.tagline}
          </p>
        </section>

        <section class="px-5 pt-6 pb-7 lg:p-0">
          <h2 class="text-[15px] lg:text-base font-semibold mb-[14px] lg:mb-[22px]">Featured projects</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-[14px] lg:gap-[22px]">
            {featured.map((project) => <ProjectCard project={project} />)}
          </div>
        </section>

        <section class="px-5 pb-7 lg:p-0 lg:mt-14">
          <div class="flex items-center justify-between mb-[14px] lg:mb-[22px]">
            <h2 class="text-[15px] lg:text-base font-semibold">Other projects</h2>
            <Pager pages={otherPages} label="Other project pages" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-[14px] lg:gap-[22px]">
            {others.map((project) => <ProjectCard project={project} />)}
          </div>

          <!-- Static dots until pagination is wired up -->
          <div class="flex lg:hidden justify-center gap-2 pt-4" aria-hidden="true">
            {
              Array.from({ length: otherPages }, (_, i) => (
                <span class:list={['w-2 h-2 rounded-full', i === 0 ? 'bg-primary' : 'bg-[#b8b6a8]']} />
              ))
            }
          </div>
        </section>
      </main>

      <Footer />
    </div>
  </div>
</Layout>
