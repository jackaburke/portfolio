---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { site } from '../site.config';
---

<Layout title={`Something went wrong — ${site.name}`}>
  <Navbar />
  <main id="main" class="flex flex-col items-center text-center px-6 py-24">
    <p class="font-mono text-nav text-faint mb-3">500</p>
    <h1 class="text-heading lg:text-heading-lg font-semibold mb-2">Something went wrong</h1>
    <p class="text-body font-medium text-muted mb-6">Try again in a moment.</p>
    <a href="/" class="text-nav font-medium text-link no-underline">&larr; Back to the homepage</a>
  </main>
</Layout>
