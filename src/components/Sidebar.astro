---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { site } from '../site.config';
import profilePhoto from '../assets/profile-photo.jpg';
---

<aside
  aria-label="Profile"
  class="bg-primary flex flex-col items-center text-center px-6 pt-[30px] pb-7 border-b border-divider-strong
         lg:w-[290px] xl:w-[325px] lg:flex-none lg:items-start lg:text-left lg:px-9 xl:px-11 lg:pt-[52px] lg:pb-[60px] lg:border-b-0 lg:border-r"
>
  <Image
    src={profilePhoto}
    alt={site.name}
    width={300}
    height={300}
    densities={[1, 2]}
    loading="eager"
    fetchpriority="high"
    class="profile-photo w-[110px] h-[110px] lg:w-[150px] lg:h-[150px] rounded-full border-[1.5px] border-[rgba(240,238,227,.4)] flex-none object-cover"
  />

  <h1 class="profile-name mt-4 lg:mt-[26px] mb-[2px] lg:mb-[3px] text-name font-semibold text-inverse">
    {site.name}
  </h1>
  <p class="mb-4 lg:mb-5 text-detail font-medium text-accent">{site.role}</p>

  <div class="socials flex flex-col gap-2 w-full mb-[22px] lg:mb-9">
    <div class="flex gap-2">
      <a href={site.links.linkedin} target="_blank" rel="noopener" class="social-btn">
        <Icon name="ri:linkedin-line" class="w-[14px] h-[14px] lg:w-[15px] lg:h-[15px]" aria-hidden="true" />
        LinkedIn<span class="sr-only"> (opens in new tab)</span>
      </a>
      <a href={site.links.github} target="_blank" rel="noopener" class="social-btn">
        <Icon name="lucide:github" class="w-[14px] h-[14px] lg:w-[15px] lg:h-[15px]" aria-hidden="true" />
        GitHub<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
    <a href={`mailto:${site.links.email}`} class="social-btn">
      <Icon name="lucide:mail" class="w-[14px] h-[14px] lg:w-[15px] lg:h-[15px]" aria-hidden="true" />
      Email
    </a>
  </div>

  <dl class="detail flex flex-col gap-[14px] lg:gap-[26px] w-full text-left">
    {
      site.details.map((row) => (
        <div>
          <dt>{row.label}</dt>
          <dd>
            {row.value}
            {row.note && <span class="block text-caption text-inverse-muted">{row.note}</span>}
          </dd>
        </div>
      ))
    }
  </dl>
</aside>
