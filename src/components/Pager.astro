---
// Static placeholder — pagination gets wired up later
interface Props {
  pages: number;
  label: string;
}

const { pages, label } = Astro.props;
const numbers = Array.from({ length: pages }, (_, i) => i + 1);
---

<nav class="hidden lg:flex items-center gap-2" aria-label={label}>
  {
    numbers.map((n) => (
      <button
        type="button"
        aria-label={`Page ${n}`}
        aria-current={n === 1 ? 'page' : undefined}
        class:list={[
          'min-w-[28px] h-7 rounded-[3px] text-[12.5px] font-medium',
          n === 1 ? 'bg-primary text-inverse' : 'bg-surface text-chip-foreground',
        ]}
      >
        {n}
      </button>
    ))
  }
</nav>
